# .env.example — Copia in .env e compila con i tuoi valori

# ── Bot Discord ───────────────────────────────────────────────────────────────
DISCORD_TOKEN=il_tuo_token_bot_discord

# ── Spotify (opzionale) ───────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=il_tuo_spotify_client_id
SPOTIFY_CLIENT_SECRET=il_tuo_spotify_client_secret

# ── Dashboard Web ─────────────────────────────────────────────────────────────
# Recupera DISCORD_CLIENT_ID e DISCORD_CLIENT_SECRET dal Discord Developer Portal:
# https://discord.com/developers/applications → la tua app → OAuth2
DISCORD_CLIENT_ID=il_tuo_discord_client_id
DISCORD_CLIENT_SECRET=il_tuo_discord_client_secret

# URL pubblico del servizio (es. https://mazibot.up.railway.app)
DASHBOARD_URL=http://localhost:8080

# Stringa casuale per firmare i cookie di sessione.
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_con_una_stringa_casuale_lunga
